# Backend Environment Configuration

This file should be created at `/backend/.env` on your Azure VM.

# ========================================
# Database Configuration
# ========================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=sales_admin
DB_PASSWORD=demo@123
DB_NAME=company_sales

# ========================================
# API Keys
# ========================================
# Get your OpenRouter API key from: https://openrouter.ai/keys
# FREE tier: 50 requests/day, 20 requests/minute
# IMPORTANT: Use models with :free suffix to access free tier
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ========================================
# JWT Configuration
# ========================================
# Generate a secure random string for production
# Example: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ========================================
# Server Configuration
# ========================================
API_PORT=8000
API_HOST=0.0.0.0
ENVIRONMENT=production

# ========================================
# CORS Configuration
# ========================================
# Add your Vercel domain here (comma-separated for multiple origins)
CORS_ORIGINS=https://hackthon-demo-ten.vercel.app,http://localhost:3000

# ========================================
# Database Connection Pool
# ========================================
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20

# ========================================
# IMPORTANT NOTES
# ========================================
# 1. NEVER commit this file to Git
# 2. Keep JWT_SECRET_KEY secure and unique
# 3. Change default passwords in production
# 4. Get your OpenRouter API key from https://openrouter.ai/keys (FREE tier)
# 5. Update CORS_ORIGINS with your actual frontend domain
